{
  "name": "@wf/conversation-worker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./pipeline": {
      "types": "./dist/pipeline.d.ts",
      "import": "./dist/pipeline.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run src --passWithNoTests",
    "lint": "tsc -p tsconfig.json --noEmit",
    "dev": "tsx watch src/index.ts"
  },
  "dependencies": {
    "@wf/agent-tools": "workspace:*",
    "@wf/connectors": "workspace:*",
    "@wf/db": "workspace:*",
    "@wf/queue": "workspace:*",
    "@wf/shared": "workspace:*",
    "bullmq": "^5.65.0"
  },
  "devDependencies": {
    "vitest": "^4.0.14"
  }
}
