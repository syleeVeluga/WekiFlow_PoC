NODE_ENV=development
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=wekiflow
REDIS_URL=redis://localhost:6379
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_USE_SSL=false
AGENT_MODEL=gpt-5.5
EMBEDDING_MODEL=text-embedding-3-large
TRIPLET_GOOGLE_MODEL=gemini-3.1-flash-lite
TRIPLET_ANTHROPIC_MODEL=claude-haiku-4-5-20251001
TRIPLET_OPENAI_FALLBACK_MODEL=gpt-5.4-nano
DOCKER_SOCKET=//./pipe/docker_engine
VECTOR_SEARCH_MODE=app-cosine
WKF_BUNDLE_PATH=knowledge
MAIN_WORKER_CONCURRENCY=2
GRAPH_WORKER_CONCURRENCY=2
CURATION_WORKER_CONCURRENCY=1
MAIN_QUEUE_RATE_MAX=30
MAIN_QUEUE_RATE_DURATION_MS=60000
GRAPH_QUEUE_RATE_MAX=60
GRAPH_QUEUE_RATE_DURATION_MS=60000
CURATION_QUEUE_RATE_MAX=30
CURATION_QUEUE_RATE_DURATION_MS=60000
# 테스트 소유자 계정 (이메일 로그인). 비밀번호는 PoC상 평문이며 이메일과 동일.
ADMIN_EMAIL=admin01@veluga.io
ADMIN_PASSWORD=admin01@veluga.io

# AI provider credentials. Graph triplet extraction uses Google, then Anthropic, then OpenAI fallback.
# Keep real keys only in .env.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# Connector credentials are placeholders only. Keep real values in local .env or a secret manager.
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=
GOOGLE_DRIVE_CLIENT_ID=
GOOGLE_DRIVE_CLIENT_SECRET=
GOOGLE_DRIVE_REFRESH_TOKEN=
MEETING_TRANSCRIPT_BUCKET=
CONNECTOR_URL_ALLOWLIST=
