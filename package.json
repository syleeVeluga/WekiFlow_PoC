{
  "name": "wekiflow-poc",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=24 <25"
  },
  "scripts": {
    "build": "corepack pnpm -r build",
    "typecheck": "corepack pnpm --filter @wf/shared build && corepack pnpm -r typecheck",
    "test": "corepack pnpm -r test",
    "lint": "corepack pnpm -r lint",
    "poc:sandbox": "tsx scripts/poc-sandbox-grep.ts",
    "poc:lightrag": "tsx scripts/poc-lightrag-extract.ts",
    "seed:wiki": "tsx scripts/seed-wiki.ts",
    "backfill:wiki": "tsx scripts/backfill-wiki.ts",
    "poc:hybrid": "tsx scripts/poc-hybrid-rag.ts",
    "poc:agent": "tsx scripts/poc-main-agent.ts",
    "verify:testing": "corepack pnpm build && corepack pnpm -r typecheck && corepack pnpm -r test && corepack pnpm poc:sandbox && corepack pnpm poc:lightrag && corepack pnpm -r lint",
    "verify:goal": "corepack pnpm build && corepack pnpm test && corepack pnpm poc:lightrag && corepack pnpm poc:hybrid"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.14"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.67",
    "@wf/agent-tools": "workspace:*",
    "@wf/db": "workspace:*",
    "@wf/sandbox": "workspace:*",
    "@wf/shared": "workspace:*",
    "ai": "^6.0.193",
    "mongodb": "^6.18.0"
  }
}
